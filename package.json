{
  "name": "karabinervia",
  "version": "0.1.0",
  "description": "A MacBook keyboard layer planner and Karabiner-Elements config exporter based on the VIA frontend.",
  "license": "GPL-3.0",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc && tsc -p tsconfig.node.json && tsc -p tsconfig.test.json",
    "build": "pnpm typecheck && vite build",
    "oxfmt": "oxfmt --write .",
    "oxlint": "oxlint src __tests__ vite.config.ts vitest.config.ts playwright.config.ts --max-warnings=0",
    "lint": "pnpm oxfmt && pnpm oxlint",
    "audit": "pnpm audit --audit-level moderate",
    "preview": "vite preview",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:unit:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:e2e": "playwright test",
    "verify": "pnpm audit && pnpm lint && pnpm typecheck && pnpm test:unit:coverage && pnpm test:e2e && pnpm pack:dry-run",
    "prepack": "pnpm build",
    "pack:dry-run": "pnpm pack --dry-run"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@react-hook/resize-observer": "^2.0.2",
    "@reduxjs/toolkit": "^2.12.0",
    "@the-via/reader": "^1.13.0",
    "downshift": "^9.3.6",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "lodash.partition": "^4.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-is": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-select": "^5.10.2",
    "styled-components": "^6.4.2",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash.partition": "^4.6.9",
    "@types/node": "^24.10.15",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.17.0"
  },
  "packageManager": "pnpm@11.5.3"
}
